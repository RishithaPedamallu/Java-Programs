import java.io.*;

class FileExample {
    public static void main(String[] args) throws Exception {
        int arr[] = {1,2,3,4,5};

        FileWriter even = new FileWriter("Even.txt");
        FileWriter odd = new FileWriter("Odd.txt");

        for(int n : arr) {
            if(n % 2 == 0)
                even.write(n + " ");
            else
                odd.write(n + " ");
        }

        even.close();
        odd.close();
    }
}

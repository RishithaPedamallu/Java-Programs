import java.util.*;

class MapExample {
    public static void main(String[] args) {
        HashMap<Integer,String> hm = new HashMap<>();
        hm.put(1,"A");

        TreeMap<Integer,String> tm = new TreeMap<>();
        tm.put(2,"B");

        System.out.println(hm);
        System.out.println(tm);
    }
}

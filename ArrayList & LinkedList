import java.util.*;

class ListExample {
    public static void main(String[] args) {
        ArrayList<Integer> a = new ArrayList<>();
        a.add(10);
        a.add(20);

        LinkedList<Integer> l = new LinkedList<>();
        l.add(30);
        l.add(40);

        System.out.println(a);
        System.out.println(l);
    }
}

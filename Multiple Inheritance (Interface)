interface A {
    void a();
}

interface B {
    void b();
}

class C implements A, B {
    public void a() {
        System.out.println("A");
    }

    public void b() {
        System.out.println("B");
    }

    public static void main(String[] args) {
        C obj = new C();
        obj.a();
        obj.b();
    }
}

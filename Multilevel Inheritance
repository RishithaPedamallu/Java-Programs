class A {
    void show() {
        System.out.println("A");
    }
}

class B extends A {
    void showB() {
        System.out.println("B");
    }
}

class C extends B {
    void showC() {
        System.out.println("C");
    }

    public static void main(String[] args) {
        C obj = new C();
        obj.show();
        obj.showB();
        obj.showC();
    }
}
